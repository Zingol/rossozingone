---
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { siteConfig } from '../config';
import '../styles/global.css';
import CookieBanner from '../components/CookieBanner.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
  breadcrumbs?: Array<{ name: string; href: string }>;
  schemaService?: {
    name: string;
    description: string;
    url: string;
  };
  faqSchema?: Array<{ question: string; answer: string }>;
}

const {
  title,
  description = siteConfig.description,
  ogImage = '/og-image.jpg',
  noindex = false,
  breadcrumbs,
  schemaService,
  faqSchema,
} = Astro.props;

const pageTitle = title === 'Home'
  ? `${siteConfig.name} — ${siteConfig.tagline}`
  : `${title} | ${siteConfig.name}`;

const canonicalUrl = new URL(Astro.url.pathname, siteConfig.url).href;
const ogImageUrl = new URL(ogImage, siteConfig.url).href;

// Schema Organization + LocalBusiness
const schemaOrg = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": ["Organization", "LocalBusiness", "ProfessionalService"],
      "@id": `${siteConfig.url}/#organization`,
      name: siteConfig.legalName,
      url: siteConfig.url,
      logo: `${siteConfig.url}/favicon.svg`,
      image: ogImageUrl,
      description: siteConfig.description,
      foundingDate: String(siteConfig.yearFounded),
      founder: {
        "@type": "Person",
        "@id": `${siteConfig.url}/#person`,
        name: siteConfig.founder,
        jobTitle: "Fractional CMO / CEO",
        url: siteConfig.url,
        sameAs: [siteConfig.linkedin],
      },
      address: {
        "@type": "PostalAddress",
        streetAddress: siteConfig.address.street,
        addressLocality: siteConfig.address.city,
        addressRegion: siteConfig.address.province,
        postalCode: siteConfig.address.cap,
        addressCountry: "IT",
      },
      geo: {
        "@type": "GeoCoordinates",
        latitude: 43.9096,
        longitude: 12.9136,
      },
      contactPoint: {
        "@type": "ContactPoint",
        telephone: siteConfig.phone,
        email: siteConfig.email,
        contactType: "customer service",
        availableLanguage: ["Italian", "English"],
      },
      areaServed: [
        { "@type": "Country", name: "Italy" },
        { "@type": "Country", name: "Germany" },
        { "@type": "Country", name: "Austria" },
        { "@type": "Country", name: "Switzerland" },
        { "@type": "Country", name: "United Kingdom" },
      ],
      sameAs: [siteConfig.linkedin],
      numberOfEmployees: {
        "@type": "QuantitativeValue",
        value: 4,
      },
      aggregateRating: {
        "@type": "AggregateRating",
        ratingValue: "5",
        reviewCount: "7",
        bestRating: "5",
        worstRating: "1",
      },
    },
    // BreadcrumbList
    ...(breadcrumbs ? [{
      "@type": "BreadcrumbList",
      "@id": `${canonicalUrl}#breadcrumb`,
      itemListElement: [
        {
          "@type": "ListItem",
          position: 1,
          name: "Home",
          item: siteConfig.url,
        },
        ...breadcrumbs.map((crumb, i) => ({
          "@type": "ListItem",
          position: i + 2,
          name: crumb.name,
          item: new URL(crumb.href, siteConfig.url).href,
        })),
      ],
    }] : []),
    // Service Schema (opzionale per pagine servizi)
    ...(schemaService ? [{
      "@type": "Service",
      "@id": `${canonicalUrl}#service`,
      name: schemaService.name,
      description: schemaService.description,
      url: schemaService.url,
      provider: {
        "@id": `${siteConfig.url}/#organization`,
      },
      areaServed: { "@type": "Country", name: "Italy" },
    }] : []),
    // FAQ Schema (opzionale)
    ...(faqSchema ? [{
      "@type": "FAQPage",
      "@id": `${canonicalUrl}#faq`,
      mainEntity: faqSchema.map((item) => ({
        "@type": "Question",
        name: item.question,
        acceptedAnswer: {
          "@type": "Answer",
          text: item.answer,
        },
      })),
    }] : []),
  ],
};
---

<!doctype html>
<html lang="it">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />

  <title>{pageTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />

  {noindex && <meta name="robots" content="noindex, nofollow" />}

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=DM+Serif+Display&display=swap"
    rel="stylesheet"
  />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:site_name" content={siteConfig.name} />
  <meta property="og:locale" content="it_IT" />
  <meta property="og:image" content={ogImageUrl} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content={pageTitle} />

  <!-- Twitter / X Cards -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={pageTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageUrl} />

  <!-- Schema.org JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify(schemaOrg)} />
</head>
<body>
  <Navbar />
  <main id="main" style="margin-top: 72px;">
    <slot />
  </main>
  <Footer />

  <script>
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
    );
    document.querySelectorAll('.fade-in').forEach((el) => observer.observe(el));
  </script>
  <CookieBanner />
</body>
</html>