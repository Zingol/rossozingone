---
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { siteConfig } from '../config';
import '../styles/global.css';
import CookieBanner from '../components/CookieBanner.astro';
import AiChat from "../components/AiChat.astro";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
  breadcrumbs?: Array<{ name: string; href: string }>;
  schemaService?: {
    name: string;
    description: string;
    url: string;
    serviceType?: string;
  };
  faqSchema?: Array<{ question: string; answer: string }>;
  articleSchema?: {
    headline: string;
    description: string;
    datePublished: string;
    dateModified?: string;
    image?: string;
  };
}

const {
  title,
  description = siteConfig.description,
  ogImage = '/og-image.jpg',
  noindex = false,
  breadcrumbs,
  schemaService,
  faqSchema,
  articleSchema,
} = Astro.props;

const pageTitle = `${title} | ${siteConfig.name}`;

const canonicalUrl = new URL(Astro.url.pathname, siteConfig.url).href;
const ogImageUrl = new URL(ogImage, siteConfig.url).href;

const schemaOrg = {
  "@context": "https://schema.org",
  "@graph": [
    // ─── ORGANIZATION ───
    {
      "@type": ["Organization", "LocalBusiness", "ProfessionalService"],
      "@id": `${siteConfig.url}/#organization`,
      name: siteConfig.legalName,
      alternateName: "RossoZingone",
      url: siteConfig.url,
      logo: `${siteConfig.url}/favicon.svg`,
      image: ogImageUrl,
      description: siteConfig.description,
      foundingDate: String(siteConfig.yearFounded),
      vatID: `IT${siteConfig.piva}`,
      taxID: `IT${siteConfig.piva}`,
      priceRange: "\u20AC\u20AC\u20AC",
      telephone: siteConfig.phone,
      founder: {
        "@id": `${siteConfig.url}/#person`,
      },
      address: {
        "@type": "PostalAddress",
        streetAddress: siteConfig.address.street,
        addressLocality: siteConfig.address.city,
        addressRegion: siteConfig.address.province,
        postalCode: siteConfig.address.cap,
        addressCountry: "IT",
      },
      geo: {
        "@type": "GeoCoordinates",
        latitude: 43.9069708,
        longitude: 12.9082051,
      },
      contactPoint: {
        "@type": "ContactPoint",
        telephone: siteConfig.phone,
        email: siteConfig.email,
        contactType: "customer service",
        availableLanguage: ["Italian", "English"],
      },
      areaServed: [
        { "@type": "Country", name: "Italy" },
        { "@type": "Country", name: "Germany" },
        { "@type": "Country", name: "Austria" },
        { "@type": "Country", name: "Switzerland" },
        { "@type": "Country", name: "United Kingdom" },
      ],
      sameAs: [siteConfig.linkedin],
      numberOfEmployees: {
        "@type": "QuantitativeValue",
        value: 4,
      },
      aggregateRating: {
        "@type": "AggregateRating",
        ratingValue: "5",
        reviewCount: "8",
        bestRating: "5",
        worstRating: "1",
      },
      hasOfferCatalog: {
        "@type": "OfferCatalog",
        name: "Servizi",
        itemListElement: [
          {
            "@type": "Offer",
            itemOffered: {
              "@type": "Service",
              name: "Fractional Executive (CMO/CEO)",
              description: `Direzione marketing e gestione aziendale part-time per PMI italiane. Entro nel sistema decisionale dell'azienda come direttore — marketing, business development, go-to-market.`,
            },
          },
          {
            "@type": "Offer",
            itemOffered: {
              "@type": "Service",
              name: "AI Integration per PMI",
              description: `Integrazione dell'intelligenza artificiale nei processi aziendali reali. L'AI nel metodo di lavoro, non come progetto separato.`,
            },
          },
          {
            "@type": "Offer",
            itemOffered: {
              "@type": "Service",
              name: "Advisory e Diagnostica Aziendale",
              description: "Discovery Session, diagnostica BDS, analisi di business e business plan. I dati prima delle opinioni.",
            },
          },
        ],
      },
    },
    // ─── PERSON ───
    {
      "@type": "Person",
      "@id": `${siteConfig.url}/#person`,
      name: siteConfig.founder,
      url: `${siteConfig.url}/chi-sono/`,
      image: `${siteConfig.url}/francesco-zingone.jpg`,
      jobTitle: "Fractional CMO & CEO, AI-Integrated",
      description: "Fractional Executive per PMI italiane. 28 anni di esperienza in marketing strategico e general management. General Management SDA Bocconi.",
      worksFor: {
        "@id": `${siteConfig.url}/#organization`,
      },
      alumniOf: {
        "@type": "EducationalOrganization",
        name: "SDA Bocconi School of Management",
      },
      memberOf: [
        {
          "@type": "Organization",
          name: "Fractional Manager Italia",
          url: "https://fractionalmanageritalia.it",
        },
        {
          "@type": "Organization",
          name: "FederManager",
          url: "https://www.federmanager.it",
        },
        {
          "@type": "Organization",
          name: "AICIM",
          url: "https://www.aicim.it",
        },
      ],
      knowsAbout: [
        "Marketing Strategico per PMI",
        "General Management",
        "AI Integration per piccole e medie imprese",
        "Consulenza Direzionale Fractional",
      ],
      sameAs: [
        siteConfig.linkedin,
        "https://www.instagram.com/francesco_zingone/",
        "https://www.wikidata.org/wiki/Q140322111",
        "https://www.facebook.com/francesco.zingone",
        "https://x.com/F_Zingone",
      ],
    },
    // ─── WEBSITE ───
    {
      "@type": "WebSite",
      "@id": `${siteConfig.url}/#website`,
      name: siteConfig.name,
      url: siteConfig.url,
      publisher: {
        "@id": `${siteConfig.url}/#organization`,
      },
      description: siteConfig.description,
    },
    // ─── FRACTIONAL MANAGER (entità fondata) ───
    {
      "@type": "Organization",
      name: "Fractional Manager",
      url: "https://fractionalmanager.me",
      founder: {
        "@id": `${siteConfig.url}/#person`,
      },
    },
    // ─── BREADCRUMB (condizionale) ───
    ...(breadcrumbs ? [{
      "@type": "BreadcrumbList",
      "@id": `${canonicalUrl}#breadcrumb`,
      itemListElement: [
        {
          "@type": "ListItem",
          position: 1,
          name: "Home",
          item: siteConfig.url,
        },
        ...breadcrumbs.map((crumb, i) => ({
          "@type": "ListItem",
          position: i + 2,
          name: crumb.name,
          item: new URL(crumb.href, siteConfig.url).href,
        })),
      ],
    }] : []),
    // ─── SERVICE (condizionale) ───
    ...(schemaService ? [{
      "@type": "Service",
      "@id": `${canonicalUrl}#service`,
      name: schemaService.name,
      description: schemaService.description,
      url: schemaService.url,
      provider: {
        "@id": `${siteConfig.url}/#organization`,
      },
      areaServed: { "@type": "Country", name: "Italy" },
      ...(schemaService.serviceType ? { serviceType: schemaService.serviceType } : {}),
    }] : []),
    // ─── FAQ (condizionale) ───
    ...(faqSchema ? [{
      "@type": "FAQPage",
      "@id": `${canonicalUrl}#faq`,
      mainEntity: faqSchema.map((item) => ({
        "@type": "Question",
        name: item.question,
        acceptedAnswer: {
          "@type": "Answer",
          text: item.answer,
        },
      })),
    }] : []),
    // ─── ARTICLE (condizionale) ───
    ...(articleSchema ? [{
      "@type": "Article",
      "@id": `${canonicalUrl}#article`,
      headline: articleSchema.headline,
      description: articleSchema.description,
      datePublished: articleSchema.datePublished,
      dateModified: articleSchema.dateModified ?? articleSchema.datePublished,
      image: articleSchema.image ? new URL(articleSchema.image, siteConfig.url).href : ogImageUrl,
      author: {
        "@id": `${siteConfig.url}/#person`,
      },
      publisher: {
        "@id": `${siteConfig.url}/#organization`,
      },
      mainEntityOfPage: {
        "@type": "WebPage",
        "@id": canonicalUrl,
      },
    }] : []),
  ],
};
---

<!doctype html>
<html lang="it">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />

  <!-- Google Consent Mode v2 — Default denied -->
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('consent', 'default', {
      'analytics_storage': 'denied',
      'ad_storage': 'denied',
      'ad_user_data': 'denied',
      'ad_personalization': 'denied'
    });
    var storedConsent = localStorage.getItem('cookie-consent');
    if (storedConsent === 'accepted') {
      gtag('consent', 'update', {
        'analytics_storage': 'granted'
      });
    }
  </script>

  <!-- Google Tag Manager -->
  <script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
  new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
  j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
  'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
  })(window,document,'script','dataLayer','GTM-PD5M62N');</script>
  <!-- End Google Tag Manager -->

  <title>{pageTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />

  {noindex && <meta name="robots" content="noindex, nofollow" />}

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preload" as="style"
    href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=DM+Serif+Display&display=swap"
  />
  <link
    href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=DM+Serif+Display&display=swap"
    rel="stylesheet"
    media="print"
    onload="this.media='all'"
  />
  <noscript>
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=DM+Serif+Display&display=swap"
      rel="stylesheet"
    />
  </noscript>

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:site_name" content={siteConfig.name} />
  <meta property="og:locale" content="it_IT" />
  <meta property="og:image" content={ogImageUrl} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content={pageTitle} />

  <!-- Twitter / X Cards -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={pageTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageUrl} />

  <!-- Schema.org JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify(schemaOrg)} />
</head>
<body>
  <!-- Google Tag Manager (noscript) -->
  <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-PD5M62N"
  height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
  <!-- End Google Tag Manager (noscript) -->

  <Navbar />
  <main id="main" style="margin-top: 72px;">
    <slot />
  </main>
  <Footer />

  <script>
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
    );
    document.querySelectorAll('.fade-in').forEach((el) => observer.observe(el));
  </script>
  <CookieBanner />
  <AiChat />
  

</body>
</html>