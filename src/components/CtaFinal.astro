---
import { ctaLabel, ctaHref } from '../config';

interface Props {
  headline?: string;
  sub?: string;
}

const { headline = 'Parliamo del tuo prossimo passo.', sub = 'Parliamo del tuo contesto, dei tuoi numeri e dei tuoi obiettivi. Nessun impegno, nessun costo.' } = Astro.props;
---

<section class="section cta-final">
  <div class="container">
    <div class="cta-inner fade-in">
      <h2 class="cta-headline">{headline}</h2>
      <p class="cta-sub">{sub}</p>
      <a href={ctaHref} class="btn btn-primary btn-large">{ctaLabel}</a>
    </div>
  </div>
</section>

<style>
  .cta-final {
    background: var(--color-crema);
  }

  .cta-inner {
    text-align: center;
    max-width: 640px;
    margin: 0 auto;
    padding: 3rem 0;
  }

  .cta-headline {
    font-size: clamp(2rem, 4.5vw, 3rem);
    color: var(--color-navy);
    margin-bottom: 1rem;
  }

  .cta-sub {
    font-size: 1.0625rem;
    color: var(--color-testo-secondario);
    margin-bottom: 2.5rem;
  }

  .btn-large {
    padding: 1.125rem 3rem;
    font-size: 1rem;
  }
</style>
