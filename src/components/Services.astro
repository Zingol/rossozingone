---
const pillars = [
  {
    icon: '◆',
    title: 'Fractional CMO / CEO',
    subtitle: `Direzione strategica dall'interno`,
    body: `Non vendo giorni. Entro nel sistema decisionale della tua PMI — marketing, business development, direzione aziendale. Tutto connesso, dall'interno.`,
    body2: `Un'agenzia opera fuori. Un consulente consiglia e se ne va. Io resto finché l'azienda non cammina.`,
    cta: 'Come funziona un mandato Fractional',
    href: '/servizi/fractional-cmo-ceo/',
  },
  {
    icon: '◆',
    title: 'AI Integration',
    subtitle: `L'AI nel metodo, non nel reparto`,
    body: `L'AI non è un progetto. È il modo in cui lavoro dentro la tua azienda — ogni decisione, ogni analisi, ogni processo.`,
    body2: `Il team non deve imparare un tool. Deve diventare il tipo di organizzazione che integra l'AI naturalmente.`,
    cta: `L'approccio AI-integrated`,
    href: '/servizi/intelligenza-artificiale-per-pmi/',
  },
  {
    icon: '◆',
    title: 'Advisory & Discovery',
    subtitle: 'Prima di agire, guardo',
    body: `Discovery Session, diagnostica BDS, analisi di business — i dati prima delle opinioni.`,
    body2: `Perché nella mia esperienza, il problema di una PMI è raramente dove il titolare pensa che sia. Non perché sbaglia — perché è troppo dentro per vederlo.`,
    cta: 'Prenota una Discovery Session',
    href: 'https://tidycal.com/rossozingone',
  },
];

const competenze = [
  { label: 'Digital Marketing', href: '/servizi/digital-marketing/' },
  { label: 'Lead Generation', href: '/servizi/lead-generation/' },
  { label: 'GTM Engineering', href: '/servizi/gtm-engineering/' },
  { label: 'Business Development', href: '/servizi/business-development/' },
  { label: 'Formazione Aziendale', href: '/servizi/formazione-aziendale/' },
  { label: 'Passaggio Generazionale', href: '/servizi/passaggio-generazionale/' },
  { label: 'Fractional CAIO', href: '/servizi/fractional-caio/' },
];
---

<section class="section services" id="servizi">
  <div class="container">
    <div class="services-header fade-in">
      <h2 class="services-title">Tre pilastri.<br /><span class="services-accent">Un unico mandato.</span></h2>
    </div>

    <div class="pillars-grid">
      {pillars.map((pillar, i) => (
        <div class={`pillar-card fade-in fade-in-delay-${i + 1}`}>
          <span class="pillar-icon">{pillar.icon}</span>
          <h3 class="pillar-title">{pillar.title}</h3>
          <p class="pillar-subtitle">{pillar.subtitle}</p>
          <p class="pillar-body">{pillar.body}</p>
          <p class="pillar-body pillar-body-emphasis">{pillar.body2}</p>
          <a href={pillar.href} class="pillar-link">{pillar.cta} →</a>
        </div>
      ))}
    </div>

    <div class="competenze fade-in">
      <h3 class="competenze-title">Dentro un mandato, queste sono le competenze</h3>
      <p class="competenze-ponte">Competenze diverse, una sola testa che le connette.</p>
      <div class="competenze-grid">
        {competenze.map((c) => (
          <a href={c.href} class="competenza-link">{c.label}</a>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .services {
    background: var(--color-crema);
  }

  .services-header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .services-title {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
  }

  .services-accent {
    color: var(--color-rosso);
  }

  /* ─── PILLAR CARDS ─── */
  .pillars-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  @media (min-width: 1024px) {
    .pillars-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .pillar-card {
    background: var(--color-bianco);
    border-radius: 6px;
    padding: 2.5rem 2rem;
    border: 1px solid var(--color-bordo);
    transition: box-shadow 0.3s ease, transform 0.3s ease;
    display: flex;
    flex-direction: column;
  }

  .pillar-card:hover {
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.06);
    transform: translateY(-2px);
  }

  .pillar-icon {
    display: block;
    font-size: 1.25rem;
    color: var(--color-rosso);
    margin-bottom: 1.25rem;
  }

  .pillar-title {
    font-family: var(--font-display);
    font-size: 1.5rem;
    color: var(--color-navy);
    margin-bottom: 0.25rem;
    line-height: 1.2;
  }

  .pillar-subtitle {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-testo-secondario);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 1.5rem;
  }

  .pillar-body {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--color-testo);
    margin-bottom: 0.75rem;
  }

  .pillar-body-emphasis {
    color: var(--color-testo-secondario);
    font-style: italic;
    margin-bottom: 1.5rem;
    flex-grow: 1;
  }

  .pillar-link {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-rosso);
    text-decoration: none;
    transition: color 0.2s ease;
    margin-top: auto;
  }

  .pillar-link:hover {
    color: var(--color-rosso-dark);
  }

  /* ─── COMPETENZE SUBORDINATE ─── */
  .competenze {
    margin-top: 4rem;
    text-align: center;
  }

  .competenze-title {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-testo-secondario);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 0.25rem;
  }

  .competenze-ponte {
    font-size: 0.875rem;
    color: var(--color-testo-secondario);
    font-style: italic;
    margin-bottom: 1.5rem;
  }

  .competenze-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
  }

  .competenza-link {
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-testo);
    text-decoration: none;
    padding: 0.5rem 1.25rem;
    border: 1px solid var(--color-bordo);
    border-radius: 100px;
    transition: all 0.2s ease;
  }

  .competenza-link:hover {
    border-color: var(--color-rosso);
    color: var(--color-rosso);
    background: rgba(165, 32, 32, 0.03);
  }
</style>
