---
const services = [
  {
    icon: '◆',
    title: 'Fractional CMO/CEO',
    subtitle: 'Direzione Strategica PMI',
    description: 'Direzione marketing e gestione aziendale part-time. Competenze executive nella tua azienda 1-3 giorni a settimana, senza il costo di un manager a tempo pieno.',
    items: ['Marketing strategico e operativo', 'General Management e pianificazione', 'Business Development e crescita controllata', 'Discovery Day: diagnostica iniziale'],
    href: '/servizi/#fractional',
  },
  {
    icon: '◆',
    title: 'AI Integration',
    subtitle: 'Intelligenza Artificiale per PMI',
    description: 'Integrazione dell\'AI nei processi aziendali reali. Dove crea valore, non dove fa scena. Approccio privacy-first con elaborazione locale per dati sensibili.',
    items: ['Analisi processi e opportunità AI', 'Automazione workflow e processi', 'AI Agents e chatbot aziendali', 'Privacy-first con Ollama locale'],
    href: '/servizi/#ai-integration',
  },
  {
    icon: '◆',
    title: 'Passaggio Generazionale',
    subtitle: 'Affiancamento Operativo',
    description: 'Coaching pratico per le nuove generazioni che entrano nelle PMI familiari. Non motivazione — risultati concreti dentro l\'azienda.',
    items: ['Affiancamento giovani imprenditori', 'Ponte tra esperienza e innovazione', 'Formazione operativa sul campo', 'Gestione della transizione'],
    href: '/servizi/#passaggio-generazionale',
  },
];
---

<section class="section services" id="servizi">
  <div class="container">
    <div class="services-header fade-in">
      <h2 class="services-title">Tre competenze integrate<br /><span class="services-accent">per far crescere la tua PMI.</span></h2>
    </div>

    <div class="services-grid">
      {services.map((service, i) => (
        <div class={`service-card fade-in fade-in-delay-${i + 1}`}>
          <span class="service-icon">{service.icon}</span>
          <h3 class="service-title">{service.title}</h3>
          <p class="service-subtitle">{service.subtitle}</p>
          <p class="service-description">{service.description}</p>
          <ul class="service-items">
            {service.items.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
          <a href={service.href} class="service-link">Approfondisci →</a>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .services {
    background: var(--color-crema);
  }

  .services-header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .services-title {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
  }

  .services-accent {
    color: var(--color-rosso);
  }

  .services-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  @media (min-width: 768px) {
    .services-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .service-card {
    background: var(--color-bianco);
    border-radius: 6px;
    padding: 2.5rem 2rem;
    border: 1px solid var(--color-bordo);
    transition: box-shadow 0.3s ease, transform 0.3s ease;
  }

  .service-card:hover {
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.06);
    transform: translateY(-2px);
  }

  .service-icon {
    display: block;
    font-size: 1.25rem;
    color: var(--color-rosso);
    margin-bottom: 1.25rem;
  }

  .service-title {
    font-family: var(--font-display);
    font-size: 1.5rem;
    color: var(--color-navy);
    margin-bottom: 0.25rem;
    line-height: 1.2;
  }

  .service-subtitle {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-testo-secondario);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 1.25rem;
  }

  .service-description {
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--color-testo);
    margin-bottom: 1.5rem;
  }

  .service-items {
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .service-items li {
    font-size: 0.875rem;
    color: var(--color-testo-secondario);
    padding-left: 1.25rem;
    position: relative;
  }

  .service-items li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.5em;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-rosso);
  }

  .service-link {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-rosso);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .service-link:hover {
    color: var(--color-rosso-dark);
  }
</style>