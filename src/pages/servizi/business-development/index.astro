    badge: 'Food Retail — Pesaro',
    type: 'Internazionalizzazione',
    description: 'Advisory strategico per l\'apertura a nuovi mercati internazionali. Analisi dei mercati target, valutazione opportunità e supporto operativo al processo di internazionalizzazione.',
    services: ['Internazionalizzazione', 'Analisi mercati esteri', 'Strategia di ingresso'],
    testimonial: {
      quote: 'Grazie al suo supporto siamo stati in grado di affacciarci a nuove prospettive di crescita, soprattutto nei processi di internazionalizzazione.',
      name: 'Marco Gori',
      role: 'Project Manager, BKR Srl',
    },
  },
  {
    name: 'NF Trasporti Srl',
    badge: 'Trasporti — Longiano (FC)',
    type: 'Sviluppo commerciale e nuovi mercati',
    description: 'Analisi del mercato dei trasporti e valutazione delle opportunità di espansione. Studio dei segmenti target e supporto alla definizione della strategia di crescita.',
    services: ['Analisi di mercato', 'Sviluppo commerciale', 'Nuovi mercati'],
    testimonial: {
      quote: 'Francesco è un professionista affidabile e organizzato. Ha gestito il nostro marketing con chiarezza, rispettando i tempi e tenendoci sempre allineati.',
      name: 'Tommaso Zavatta',
      role: 'NF Trasporti Srl',
    },
  },
  {
    name: 'Giommi Srl',
    badge: 'Fossombrone',
    type: 'Business plan e strategie d\'impresa',
    description: 'Sviluppo del business plan e definizione delle strategie d\'impresa per la crescita aziendale. Analisi della struttura, identificazione leve di sviluppo e pianificazione operativa.',
    services: ['Business plan', 'Strategie d\'impresa', 'Pianificazione operativa'],
    testimonial: null,
  },
  {
    name: 'Casa Oliva',
    badge: 'Agriturismo',
