---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import CtaFinal from '../../../components/CtaFinal.astro';

const cases = [
  {
    name: 'UMPI / Digital Platforms S.p.A.',
    badge: 'Tech — Rimini',
    type: 'Go-to-market strategy',
    description: 'Definizione della strategia di go-to-market per azienda tech specializzata in sistemi di comunicazione powerline e wireless. Posizionamento prodotto, identificazione segmenti target e piano di lancio. Progetto assegnato tramite rete Fractional Manager Italia.',
    services: ['Go-to-market strategy', 'Posizionamento prodotto', 'Segmentazione mercato', 'Piano di lancio'],
    testimonial: {
      quote: 'Ti confermo che il lavoro è stato assolutamente perfetto ed apprezzato, direi che hai confermato e forse superato le aspettative.',
      name: 'Antonio Gentili',
      role: 'Founding Partner, Fractional Manager Italia',
    },
  },
  {
    name: 'BKR Srl',
    badge: 'Food Retail — Pesaro',
    type: 'Internazionalizzazione',
    description: 'Advisory strategico per l\'apertura a nuovi mercati internazionali. Analisi dei mercati target, valutazione opportunità e supporto operativo al processo di internazionalizzazione.',
    services: ['Internazionalizzazione', 'Analisi mercati esteri', 'Strategia di ingresso'],
    testimonial: {
      quote: 'Grazie al suo supporto siamo stati in grado di affacciarci a nuove prospettive di crescita, soprattutto nei processi di internazionalizzazione.',
      name: 'Marco Gori',
      role: 'Project Manager, BKR Srl',
    },
  },
  {
    name: 'NF Trasporti Srl',
    badge: 'Trasporti — Longiano (FC)',
    type: 'Sviluppo commerciale e nuovi mercati',
    description: 'Analisi del mercato dei trasporti e valutazione delle opportunità di espansione. Studio dei segmenti target e supporto alla definizione della strategia di crescita.',
    services: ['Analisi di mercato', 'Sviluppo commerciale', 'Nuovi mercati'],
    testimonial: {
      quote: 'Francesco è un professionista affidabile e organizzato. Ha gestito il nostro marketing con chiarezza, rispettando i tempi e tenendoci sempre allineati.',
      name: 'Tommaso Zavatta',
      role: 'NF Trasporti Srl',
    },
  },
  {
    name: 'Giommi Srl',
    badge: 'Fossombrone',
    type: 'Business plan e strategie d\'impresa',
    description: 'Sviluppo del business plan e definizione delle strategie d\'impresa per la crescita aziendale. Analisi della struttura, identificazione leve di sviluppo e pianificazione operativa.',
    services: ['Business plan', 'Strategie d\'impresa', 'Pianificazione operativa'],
    testimonial: null,
  },
  {
    name: 'Casa Oliva',
    badge: 'Agriturismo',
    type: 'Controllo di gestione + Business plan',
    description: 'Affiancamento sul controllo di gestione e sviluppo del business plan. Analisi della struttura dei costi, definizione degli obiettivi economici e pianificazione strategica.',
    services: ['Controllo di gestione', 'Business plan', 'Pianificazione strategica'],
    testimonial: null,
  },
];
---

<BaseLayout
  title="Business Development per PMI — Crescita e Nuovi Mercati"
  description="Identificazione e sviluppo di nuove opportunità di business per PMI italiane. Go-to-market strategy, partnership, sviluppo canali e internazionalizzazione con metodo e dati."
  breadcrumbs={[
    { name: 'Servizi', href: '/servizi/' },
    { name: 'Business Development', href: '/servizi/business-development/' },
  ]}
  schemaService={{
    name: 'Business Development',
    description: 'Business development per PMI: go-to-market strategy, partnership, sviluppo canali, internazionalizzazione.',
    url: 'https://rossozingone.it/servizi/business-development/',
  }}
  faqSchema={[
    {
      question: "Cos'è il business development per una PMI?",
      answer: "È il processo strutturato di identificazione e sviluppo di nuove opportunità di crescita: nuovi mercati, nuovi canali di vendita, nuove partnership, nuovi segmenti di clientela. Non è vendita operativa — è la strategia che precede e orienta la vendita.",
    },
    {
      question: "Quando serve un supporto esterno al business development?",
      answer: "Quando l'azienda vuole crescere ma non ha chiarezza su dove e come. Quando si lancia un nuovo prodotto o servizio su un mercato non presidiato. Quando si vuole entrare in un nuovo settore o area geografica. Quando le vendite sono piatte e si vuole capire dove sono le opportunità non sfruttate.",
    },
    {
      question: "Come si struttura un progetto di go-to-market?",
      answer: "Si parte dall'analisi del mercato target e della concorrenza, si definisce il posizionamento e la proposta di valore, si identificano i canali più efficaci per raggiungere i decision maker, si costruisce il piano operativo con obiettivi misurabili. Il tutto calibrato sulle risorse reali della PMI, non su modelli teorici.",
    },
    {
      question: "RossoZingone supporta l'internazionalizzazione?",
      answer: "Sì, con focus su mercati DACH (Germania, Austria, Svizzera) e UK. Il supporto include analisi di mercato, identificazione canali di ingresso, adattamento della comunicazione e sviluppo delle prime relazioni commerciali. Affiliato a Fractional Manager Italia per interventi che richiedono competenze complementari in loco.",
    },
  ]}
>

  <section class="section pillar">
    <div class="container">
      <div class="pillar-inner fade-in">
        <a href="/servizi/" class="back-link">← Tutti i servizi</a>
        <div class="pillar-badge">04</div>
        <h1 class="pillar-title">Business Development</h1>
        <p class="pillar-subtitle">Crescita e Nuovi Mercati</p>

        <div class="pillar-content">
          <div class="pillar-description">
            <p>Crescere non è lavorare di più sulle stesse cose. È identificare dove sono le opportunità reali, costruire la strategia per raggiungerle e poi eseguire con metodo. Il business development non è vendita — è quello che viene prima: capire il mercato, posizionarsi correttamente, aprire i canali giusti.</p>
            <p>27 anni di lavoro dentro PMI di settori diversi hanno costruito un metodo: analisi dei dati di mercato, identificazione dei segmenti più promettenti, costruzione del piano operativo con risorse reali — non modelli da startup californiana applicati a un'azienda di Pesaro.</p>
          </div>

          <div class="pillar-details">
            <div class="detail-block">
              <h3>Cosa include</h3>
              <ul>
                <li>Analisi competitiva e di mercato</li>
                <li>Identificazione segmenti e opportunità non presidiate</li>
                <li>Go-to-market strategy per nuovi prodotti e mercati</li>
                <li>Sviluppo canali di vendita e distribuzione</li>
                <li>Partnership e accordi commerciali</li>
                <li>Supporto all'internazionalizzazione (DACH, UK)</li>
                <li>Business plan operativo</li>
              </ul>
            </div>

            <div class="detail-block">
              <h3>Per chi è</h3>
              <ul>
                <li>PMI che vogliono crescere su nuovi mercati o segmenti</li>
                <li>Aziende che lanciano nuovi prodotti o linee di business</li>
                <li>Imprenditori che vogliono ridurre la dipendenza da pochi clienti</li>
                <li>Aziende che si preparano all'internazionalizzazione</li>
                <li>PMI in fase di ristrutturazione che cercano nuove fonti di ricavo</li>
              </ul>
            </div>

            <div class="detail-block">
              <h3>Metodo</h3>
              <ul>
                <li>Dati di mercato prima delle opinioni</li>
                <li>Analisi della concorrenza e del posizionamento reale</li>
                <li>Piano operativo con obiettivi misurabili e scadenze</li>
                <li>Esecuzione in affiancamento, non solo consulenza a distanza</li>
              </ul>
            </div>

            <div class="detail-block">
              <h3>Network</h3>
              <ul>
                <li>Fractional Manager Italia — rete nazionale fractional manager</li>
                <li>FederManager — dirigenti e alte professionalità</li>
                <li>Partner locali DACH e UK per internazionalizzazione</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CASI -->
  <section class="section cases-section">
    <div class="container">
      <div class="cases-header fade-in">
        <h2 class="cases-title">Esperienze.</h2>
        <p class="cases-sub">Alcuni degli interventi di business development condotti su aziende e settori diversi.</p>
      </div>

      <div class="cases-list">
        {cases.map((c) => (
          <div class="case-card fade-in">
            <div class="case-header">
              <h3 class="case-name">{c.name}</h3>
              <span class="case-badge">{c.badge}</span>
            </div>
            <div class="case-meta">
              <span class="case-type">{c.type}</span>
            </div>
            <p class="case-description">{c.description}</p>
            <div class="case-services">
              {c.services.map((s) => (
                <span class="service-tag">{s}</span>
              ))}
            </div>
            {c.testimonial && (
              <blockquote class="case-testimonial">
                <p>"{c.testimonial.quote}"</p>
                <footer>
                  <strong>{c.testimonial.name}</strong> — {c.testimonial.role}
                </footer>
              </blockquote>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  <CtaFinal />

</BaseLayout>

<style>
  .pillar {
    background: var(--color-crema);
  }

  .pillar-inner {
    max-width: 960px;
    margin: 0 auto;
  }

  .back-link {
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-testo-secondario);
    text-decoration: none;
    display: inline-block;
    margin-bottom: 1.5rem;
    transition: color 0.2s ease;
  }

  .back-link:hover {
    color: var(--color-rosso);
  }

  .pillar-badge {
    font-family: var(--font-display);
    font-size: 1.25rem;
    color: var(--color-rosso);
    margin-bottom: 1rem;
  }

  .pillar-title {
    font-size: clamp(2rem, 4.5vw, 3rem);
    margin-bottom: 0.25rem;
  }

  .pillar-subtitle {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-testo-secondario);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 2.5rem;
  }

  .pillar-content {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .pillar-description p {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--color-testo);
    margin-bottom: 1rem;
  }

  .pillar-description p:last-child {
    margin-bottom: 0;
  }

  .pillar-details {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: start;
  }

  @media (min-width: 768px) {
    .pillar-details {
      grid-template-columns: 1fr 1fr;
    }
  }

  .detail-block h3 {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-testo-secondario);
    margin-bottom: 1rem;
  }

  .detail-block ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .detail-block li {
    font-size: 0.9375rem;
    color: var(--color-testo);
    padding-left: 1.25rem;
    position: relative;
    line-height: 1.5;
  }

  .detail-block li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-rosso);
  }

  .detail-text {
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--color-testo);
  }

  /* ─── CASI ─── */
  .cases-section {
    background: var(--color-bianco);
  }

  .cases-header {
    max-width: 960px;
    margin: 0 auto 3rem auto;
  }

  .cases-title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    margin-bottom: 0.5rem;
  }

  .cases-sub {
    font-size: 0.9375rem;
    color: var(--color-testo-secondario);
    max-width: 600px;
  }

  .cases-list {
    max-width: 960px;
    margin: 0 auto;
  }

  .case-card {
    padding: 2.5rem 0;
    border-bottom: 1px solid var(--color-bordo);
  }

  .case-card:last-child {
    border-bottom: none;
  }

  .case-header {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 0.5rem;
  }

  .case-name {
    font-family: var(--font-display);
    font-size: 1.5rem;
    color: var(--color-navy);
    margin: 0;
  }

  .case-badge {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-rosso);
  }

  .case-meta {
    margin-bottom: 1.25rem;
  }

  .case-type {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-testo-secondario);
    font-style: italic;
  }

  .case-description {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--color-testo);
    margin-bottom: 1.25rem;
    max-width: 760px;
  }

  .case-services {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .service-tag {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-navy);
    padding: 0.3rem 0.75rem;
    background: var(--color-crema);
    border-radius: 100px;
    border: 1px solid var(--color-bordo);
  }

  .case-testimonial {
    background: var(--color-crema);
    border-left: 3px solid var(--color-rosso);
    padding: 1.5rem 2rem;
    margin: 0;
    border-radius: 0 6px 6px 0;
    max-width: 760px;
  }

  .case-testimonial p {
    font-size: 0.9375rem;
    font-style: italic;
    line-height: 1.7;
    color: var(--color-testo);
    margin: 0 0 0.75rem 0;
  }

  .case-testimonial footer {
    font-size: 0.8125rem;
    color: var(--color-testo-secondario);
  }

  .case-testimonial footer strong {
    color: var(--color-navy);
    font-weight: 600;
  }
</style>
