---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import CtaFinal from '../../../components/CtaFinal.astro';

const cases = [
  {
    name: 'AgeSignal',
    logo: '/loghi/logo-agesignal.svg',
    logoAlt: 'AgeSignal logo',
    badge: 'HealthTech — Ecosistema AI per la salute',
    role: 'AI Strategy & Development',
    duration: '2024–2025',
    description: 'Progetto per creare un ecosistema tecnologico basato sull\'intelligenza artificiale dedicato al supporto della popolazione anziana e dei malati cronici. La filosofia alla base: ogni persona è il miglior medico di se stesso. Strumenti pratici per monitorare proattivamente la propria salute e migliorare la comunicazione tra paziente e medico, colmando le lacune dell\'attuale sistema sanitario.',
    services: ['AI Agents per la salute', 'Monitoraggio proattivo', 'Integrazione dati sanitari', 'Privacy-first architecture'],
    testimonial: null,
  },
  {
    name: 'Trasportiamo',
    logo: '/loghi/LOGO_trasportiamo.png',
    logoAlt: 'Trasportiamo logo',
    badge: 'Logistica — Gestionale AI-powered',
    role: 'AI Strategy & Software Development',
    duration: '2024–2025',
    description: 'Sistema web professionale che automatizza il processo di gestione ordini di trasporto per un operatore logistico con modello "buy to sell". L\'azienda acquisisce commesse e le affida a una rete di trasportatori autonomi. Il software digitalizza l\'intero processo operativo — dalla creazione dell\'ordine fino alla rendicontazione mensile — semplificando la gestione amministrativa e il ciclo di fatturazione con i fornitori.',
    services: ['Automazione workflow', 'Gestionale ordini', 'Rendicontazione automatica', 'Integrazione fatturazione'],
    testimonial: null,
  },
];
---

<BaseLayout
  title="AI Integration per PMI — Intelligenza Artificiale Applicata"
  description="Integrazione dell'AI nei processi aziendali delle PMI. Privacy-first con Ollama locale, AI Agents, RAG systems, automazioni. Casi: AgeSignal, Trasportiamo."
  breadcrumbs={[
    { name: 'Servizi', href: '/servizi/' },
    { name: 'AI Integration', href: '/servizi/ai-integration/' },
  ]}
  schemaService={{
    name: 'AI Integration per PMI',
    description: "Integrazione dell'intelligenza artificiale nei processi aziendali reali delle PMI. Approccio privacy-first con elaborazione locale per dati sensibili.",
    url: 'https://rossozingone.it/servizi/ai-integration/',
  }}
  faqSchema={[
    {
      question: "Cosa significa AI Integration per una PMI?",
      answer: "Significa identificare i processi aziendali dove l'intelligenza artificiale crea valore reale — non hype — e integrarla concretamente. Automazioni, chatbot, gestione documenti, analisi dati. Il punto di partenza è sempre l'analisi del business, non la tecnologia.",
    },
    {
      question: "I miei dati aziendali sono al sicuro con l'AI?",
      answer: "Dipende da come viene implementata. Per dati sensibili utilizziamo Ollama — un sistema di AI che gira localmente sui tuoi server, senza inviare nulla a servizi esterni. Nessun dato esce dalla tua azienda. Per dati non sensibili usiamo Claude, OpenAI o Gemini con contratti di data processing adeguati.",
    },
    {
      question: "Quanto tempo serve per integrare l'AI in azienda?",
      answer: "Dipende dalla complessità. Un'automazione semplice (classificazione email, risposta automatica WhatsApp) può essere operativa in 2-4 settimane. Un sistema RAG su knowledge base aziendale richiede 1-3 mesi. Il punto di partenza è sempre un'analisi dei processi per capire dove intervenire prima.",
    },
    {
      question: "Serve personale tecnico interno per gestire l'AI?",
      answer: "No. L'obiettivo è costruire sistemi che il tuo team possa usare senza competenze tecniche. Formiamo le persone nell'uso degli strumenti e costruiamo interfacce semplici. La complessità tecnica resta nascosta sotto.",
    },
  ]}
>

  <!-- HERO + SERVIZIO -->
  <section class="section pillar">
    <div class="container">
      <div class="pillar-inner fade-in">
        <a href="/servizi/" class="back-link">← Tutti i servizi</a>
        <div class="pillar-badge">02</div>
        <h1 class="pillar-title">AI Integration per PMI</h1>
        <p class="pillar-subtitle">Intelligenza Artificiale Applicata</p>

        <div class="pillar-content">
          <div class="pillar-description">
            <p>L'AI non serve a niente se non sai dove applicarla. Io lo so perché conosco il tuo business — non arrivo con uno stack tecnologico da vendere, arrivo con 27 anni di esperienza nelle PMI italiane e individuo dove l'AI crea valore reale.</p>
            <p>Non è hype. Non è trasformazione digitale generica. È analisi dei processi, identificazione dei colli di bottiglia, automazione di quello che ha senso automatizzare. Con un approccio privacy-first per i dati sensibili.</p>
          </div>

          <div class="pillar-details">
            <div class="detail-block">
              <h3>Cosa include</h3>
              <ul>
                <li>Analisi processi aziendali — dove l'AI crea valore reale</li>
                <li>AI Agents — chatbot, assistenti, automazioni email e WhatsApp</li>
                <li>RAG systems e knowledge base aziendali</li>
                <li>Automazione workflow e processi ripetitivi</li>
                <li>Privacy-first AI con elaborazione locale (Ollama) per dati sensibili</li>
                <li>Formazione del team sull'uso dell'AI</li>
              </ul>
            </div>

            <div class="detail-block">
              <h3>Per chi è</h3>
              <ul>
                <li>PMI con processi ripetitivi che consumano tempo e risorse</li>
                <li>Aziende con dati sensibili che non possono andare su cloud esterni</li>
                <li>Imprenditori che vogliono capire dove l'AI si applica davvero al loro settore</li>
                <li>Team che hanno bisogno di formarsi sull'AI senza partire da zero</li>
              </ul>
            </div>

            <div class="detail-block">
              <h3>Stack tecnologico</h3>
              <div class="stack-grid">
                <span class="stack-tag">Claude</span>
                <span class="stack-tag">OpenAI</span>
                <span class="stack-tag">Gemini</span>
                <span class="stack-tag">Ollama (locale)</span>
              </div>
            </div>

            <div class="detail-block">
              <h3>Privacy-first</h3>
              <p class="detail-text">Per aziende con dati sensibili — clinici, legali, finanziari — l'elaborazione avviene in locale con Ollama. Nessun dato esce dall'infrastruttura aziendale. La potenza dei modelli AI senza esporre le informazioni critiche a servizi cloud esterni.</p>
            </div>
          </div>

          <div class="pillar-network">
            <h3>Network tecnico</h3>
            <p class="detail-text">Lavoro con <strong>Roberto Ricci</strong>, specialista AI e sviluppo web, per le implementazioni che richiedono ingegneria software avanzata. Questo permette di coprire l'intera filiera: dalla strategia all'implementazione tecnica, senza intermediari.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CASI PROGETTO -->
  <section class="section cases-section">
    <div class="container">
      <div class="cases-header fade-in">
        <h2 class="cases-title">Progetti.</h2>
        <p class="cases-sub">Alcuni dei progetti sviluppati nell'ambito dell'integrazione AI.</p>
      </div>

      <div class="cases-list">
        {cases.map((c) => (
          <div class="case-card fade-in">
            {c.logo && (
              <div class="case-logo">
                <img src={c.logo} alt={c.logoAlt} loading="lazy" />
              </div>
            )}

            <div class="case-header">
              <h3 class="case-name">{c.name}</h3>
              <span class="case-badge">{c.badge}</span>
            </div>

            <div class="case-meta">
              <span class="case-role">{c.role}</span>
              <span class="case-dot">·</span>
              <span class="case-duration">{c.duration}</span>
            </div>

            <p class="case-description">{c.description}</p>

            <div class="case-services">
              {c.services.map((s) => (
                <span class="service-tag">{s}</span>
              ))}
            </div>

            {c.testimonial && (
              <blockquote class="case-testimonial">
                <p>"{c.testimonial.quote}"</p>
                <footer>
                  <strong>{c.testimonial.name}</strong> — {c.testimonial.role}
                </footer>
              </blockquote>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  <CtaFinal />

</BaseLayout>

<style>
  /* ─── PILLAR SECTION ─── */
  .pillar {
    background: var(--color-crema);
  }

  .pillar-inner {
    max-width: 960px;
    margin: 0 auto;
  }

  .back-link {
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-testo-secondario);
    text-decoration: none;
    display: inline-block;
    margin-bottom: 1.5rem;
    transition: color 0.2s ease;
  }

  .back-link:hover {
    color: var(--color-rosso);
  }

  .pillar-badge {
    font-family: var(--font-display);
    font-size: 1.25rem;
    color: var(--color-rosso);
    margin-bottom: 1rem;
  }

  .pillar-title {
    font-size: clamp(2rem, 4.5vw, 3rem);
    margin-bottom: 0.25rem;
  }

  .pillar-subtitle {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-testo-secondario);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 2.5rem;
  }

  .pillar-content {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .pillar-description p {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--color-testo);
    margin-bottom: 1rem;
  }

  .pillar-description p:last-child {
    margin-bottom: 0;
  }

  .pillar-details {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: start;
  }

  @media (min-width: 768px) {
    .pillar-details {
      grid-template-columns: 1fr 1fr;
      align-items: start;
    }
  }

  .detail-block h3 {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-testo-secondario);
    margin-bottom: 1rem;
  }

  .detail-block ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .detail-block li {
    font-size: 0.9375rem;
    color: var(--color-testo);
    padding-left: 1.25rem;
    position: relative;
    line-height: 1.5;
  }

  .detail-block li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-rosso);
  }

  .detail-text {
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--color-testo);
  }

  .stack-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .stack-tag {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-navy);
    padding: 0.35rem 0.85rem;
    background: var(--color-bianco);
    border-radius: 4px;
    border: 1px solid var(--color-bordo);
    letter-spacing: 0.01em;
  }

  .pillar-network {
    padding-top: 2rem;
    border-top: 1px solid var(--color-bordo);
  }

  .pillar-network h3 {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-testo-secondario);
    margin-bottom: 0.75rem;
  }

  .pillar-network strong {
    color: var(--color-navy);
  }

  /* ─── CASI PROGETTO ─── */
  .cases-section {
    background: var(--color-bianco);
  }

  .cases-header {
    max-width: 960px;
    margin: 0 auto 3rem auto;
  }

  .cases-title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    margin-bottom: 0.5rem;
  }

  .cases-sub {
    font-size: 0.9375rem;
    color: var(--color-testo-secondario);
    max-width: 600px;
  }

  .cases-list {
    max-width: 960px;
    margin: 0 auto;
  }

  .case-card {
    padding: 2.5rem 0;
    border-bottom: 1px solid var(--color-bordo);
  }

  .case-card:last-child {
    border-bottom: none;
  }

  .case-logo {
    margin-bottom: 1.5rem;
  }

  .case-logo img {
    height: 36px;
    width: auto;
    display: block;
    object-fit: contain;
  }

  .case-header {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 0.5rem;
  }

  .case-name {
    font-family: var(--font-display);
    font-size: 1.5rem;
    color: var(--color-navy);
    margin: 0;
  }

  .case-badge {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-rosso);
  }

  .case-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
  }

  .case-role,
  .case-duration {
    font-size: 0.875rem;
    color: var(--color-testo-secondario);
  }

  .case-role {
    font-weight: 500;
  }

  .case-dot {
    color: var(--color-testo-secondario);
  }

  .case-description {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--color-testo);
    margin-bottom: 1.25rem;
    max-width: 760px;
  }

  .case-services {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .service-tag {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-navy);
    padding: 0.3rem 0.75rem;
    background: var(--color-crema);
    border-radius: 100px;
    border: 1px solid var(--color-bordo);
  }

  .case-testimonial {
    background: var(--color-crema);
    border-left: 3px solid var(--color-rosso);
    padding: 1.5rem 2rem;
    margin: 1.25rem 0 0 0;
    border-radius: 0 6px 6px 0;
    max-width: 760px;
  }

  .case-testimonial p {
    font-size: 0.9375rem;
    font-style: italic;
    line-height: 1.7;
    color: var(--color-testo);
    margin: 0 0 0.75rem 0;
  }

  .case-testimonial footer {
    font-size: 0.8125rem;
    color: var(--color-testo-secondario);
  }

  .case-testimonial footer strong {
    color: var(--color-navy);
    font-weight: 600;
  }
</style>