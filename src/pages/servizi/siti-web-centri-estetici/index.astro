<script>document.querySelectorAll('.faq-q').forEach((btn) => { btn.addEventListener('click', () => { const expanded = btn.getAttribute('aria-expanded') === 'true'; btn.setAttribute('aria-expanded', String(!expanded)); const answer = btn.nextElementSibling; if (answer) { answer.style.display = expanded ? 'none' : 'block'; } }); });</script>
