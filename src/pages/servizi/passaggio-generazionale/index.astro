---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import CtaFinal from '../../../components/CtaFinal.astro';

const cases = [
  {
    name: 'BKR Srl',
    badge: 'Food Retail — Pesaro',
    protagonisti: 'Marco Gori — nuova generazione',
    duration: '3 anni (2020–2023)',
    description: 'Affiancamento a Marco Gori nel suo percorso di crescita professionale all\'interno di BKR Srl. Un lavoro fatto dentro l\'azienda — non corsi, non slide — su marketing, comunicazione e sviluppo commerciale. Il focus sul passaggio generazionale ha incluso il supporto ai processi di internazionalizzazione, aprendo prospettive di mercato che prima non erano sul tavolo.',
    services: ['Affiancamento operativo', 'Marketing strategico', 'Internazionalizzazione', 'Sviluppo commerciale'],
    testimonial: {
      quote: 'Ho avuto il piacere di conoscere e collaborare con Francesco per circa tre anni con la mia azienda BKR Srl. Posso definirlo un mentore per la mia personale formazione professionale in ambito di Marketing e Comunicazione. Grazie al suo supporto siamo stati in grado di affacciarci a nuove prospettive di crescita, soprattutto nei processi di internazionalizzazione.',
      name: 'Marco Gori',
      role: 'Project Manager, BKR Srl',
    },
  },
  {
    name: 'Gili Edging',
    badge: 'Manufacturing — Pesaro',
    protagonisti: 'Leonardo Gili — nuova generazione · Riccardo Gili — fondatore',
    duration: '4 anni (dal 2021)',
    description: 'Affiancamento a Leonardo Gili nel percorso di ingresso e consolidamento in azienda. Il lavoro riguarda la costruzione di un ruolo autonomo e riconosciuto accanto al padre Riccardo — fondatore dell\'azienda — con un approccio pratico su marketing, posizionamento e gestione delle relazioni commerciali. Non un percorso motivazionale: un lavoro quotidiano dentro l\'azienda, sulle decisioni reali.',
    services: ['Mentoring operativo', 'Marketing strategico', 'Posizionamento brand', 'Gestione commerciale'],
    testimonial: null,
  },
  {
    name: 'Giommi Srl',
    badge: 'Fossombrone',
    protagonisti: 'Martina e Matteo Giommi — nuova generazione · Cesare Giommi — fondatore',
    duration: 'Dal 2024',
    description: 'Affiancamento a Martina e Matteo nel processo di passaggio della guida aziendale dal padre Cesare. Un lavoro su due piani: la continuità operativa — assicurarsi che quello che funziona non si perda — e l\'innovazione, portare dentro l\'azienda nuove competenze su marketing, business development e strumenti digitali. Il tutto gestendo la tensione naturale tra generazioni con visioni diverse.',
    services: ['Affiancamento generazionale', 'Business development', 'Marketing strategico', 'Continuità operativa'],
    testimonial: null,
  },
];
---

<BaseLayout
  title="Passaggio Generazionale PMI — Affiancamento"
  description="Affiancamento operativo alle nuove generazioni imprenditoriali nelle PMI familiari. Non coaching motivazionale — lavoro concreto dentro l'azienda. Casi: BKR, Gili, Giommi."
  breadcrumbs={[
    { name: 'Servizi', href: '/servizi/' },
    { name: 'Passaggio Generazionale', href: '/servizi/passaggio-generazionale/' },
  ]}
  schemaService={{
    name: 'Passaggio Generazionale',
    description: 'Affiancamento operativo alle nuove generazioni imprenditoriali nelle PMI familiari. Gestione della transizione tra generazioni con approccio pratico.',
    url: 'https://rossozingone.it/servizi/passaggio-generazionale/',
  }}
  faqSchema={[
    {
      question: "Quanto dura un percorso di passaggio generazionale?",
      answer: "Non esiste una durata standard. Dipende dalla complessità della transizione, dal livello di preparazione della nuova generazione e dalla disponibilità del fondatore a delegare. In media lavoro con le aziende per 12-36 mesi, con presenza 1-2 giorni a settimana. Il passaggio generazionale non è un evento — è un processo.",
    },
    {
      question: "Qual è la differenza tra coaching e affiancamento operativo?",
      answer: "Il coaching lavora sulla persona, in aula o in sessioni dedicate. Il mio affiancamento lavora dentro l'azienda, sulle decisioni reali, con il team reale. Non faccio role play — risolvo problemi concreti insieme alla nuova generazione mentre impara a gestirli in autonomia.",
    },
    {
      question: "Come si gestisce il conflitto tra generazioni in azienda?",
      answer: "Il conflitto generazionale in azienda nasce quasi sempre da aspettative non dichiarate e ruoli non chiari. Il mio lavoro è rendere esplicito quello che rimane implicito: chi decide cosa, in quale orizzonte temporale avviene la transizione, quali competenze deve acquisire la nuova generazione. Struttura e chiarezza riducono il conflitto.",
    },
    {
      question: "La nuova generazione deve avere già esperienza manageriale?",
      answer: "No. Spesso lavoro con figli o figlie che entrano in azienda direttamente dal percorso di studi o da esperienze in altri settori. Il punto di partenza è dove sei, non dove dovresti essere. Costruiamo le competenze necessarie nel contesto reale dell'azienda, non in aula.",
    },
  ]}
>

  <!-- HERO + SERVIZIO -->
  <section class="section pillar">
    <div class="container">
      <div class="pillar-inner fade-in">
        <a href="/servizi/" class="back-link">← Tutti i servizi</a>
        <div class="pillar-badge">05</div>
        <h1 class="pillar-title">Passaggio Generazionale</h1>
        <p class="pillar-subtitle">Affiancamento Operativo</p>

        <div class="pillar-content">
          <div class="pillar-description">
            <p>Il passaggio generazionale nelle PMI familiari non è un problema di successione — è un problema di identità. Il figlio che entra in azienda deve costruirsi un ruolo credibile senza cancellare quello che il padre ha costruito. Il padre deve lasciare spazio senza perdere il controllo. In mezzo, l'azienda deve continuare a funzionare.</p>
            <p>Entro nell'azienda e lavoro con la nuova generazione su decisioni reali, in contesti reali. Non coaching americano, non slide motivazionali. Affiancamento concreto su marketing, gestione, sviluppo commerciale — le competenze che servono per prendere in mano un'azienda.</p>
          </div>

          <div class="pillar-details">
            <div class="detail-block">
              <h3>Cosa include</h3>
              <ul>
                <li>Affiancamento operativo alla nuova generazione dentro l'azienda</li>
                <li>Costruzione di un ruolo autonomo e riconosciuto</li>
                <li>Formazione pratica su marketing, gestione e sviluppo commerciale</li>
                <li>Gestione della transizione tra generazioni</li>
                <li>Ponte tra esperienza consolidata e innovazione</li>
                <li>Supporto alle decisioni strategiche nel periodo di transizione</li>
              </ul>
            </div>

            <div class="detail-block">
              <h3>Per chi è</h3>
              <ul>
                <li>Figli di imprenditori che entrano in azienda e devono costruirsi credibilità</li>
                <li>Fondatori che vogliono trasmettere l'azienda senza perderla</li>
                <li>PMI familiari in fase di transizione generazionale</li>
                <li>Nuovi manager che devono affermarsi in un contesto già strutturato</li>
              </ul>
            </div>

            <div class="detail-block">
              <h3>Come lavoro</h3>
              <ul>
                <li>Dentro l'azienda, non in aula</li>
                <li>Su problemi reali, non su casi studio</li>
                <li>Con entrambe le generazioni, non solo con una</li>
                <li>Risultati misurabili, non percorsi di crescita personale astratti</li>
              </ul>
            </div>

            <div class="detail-block">
              <h3>Approccio</h3>
              <p class="detail-text">Il passaggio generazionale richiede tempo e va gestito senza fretta. Lavoro 1–3 giorni a settimana dentro l'azienda, con continuità. Non faccio interventi una tantum — costruisco una relazione operativa con la nuova generazione nel medio periodo.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CASI -->
  <section class="section cases-section">
    <div class="container">
      <div class="cases-header fade-in">
        <h2 class="cases-title">Casi.</h2>
        <p class="cases-sub">Tre famiglie imprenditoriali. Tre transizioni diverse. Stesso approccio: dentro l'azienda, sui problemi reali.</p>
      </div>

      <div class="cases-list">
        {cases.map((c) => (
          <div class="case-card fade-in">
            <div class="case-header">
              <h3 class="case-name">{c.name}</h3>
              <span class="case-badge">{c.badge}</span>
            </div>

            <div class="case-meta">
              <span class="case-protagonisti">{c.protagonisti}</span>
              <span class="case-dot"> · </span>
              <span class="case-duration">{c.duration}</span>
            </div>

            <p class="case-description">{c.description}</p>

            <div class="case-services">
              {c.services.map((s) => (
                <span class="service-tag">{s}</span>
              ))}
            </div>

            {c.testimonial && (
              <blockquote class="case-testimonial">
                <p>"{c.testimonial.quote}"</p>
                <footer>
                  <strong>{c.testimonial.name}</strong> — {c.testimonial.role}
                </footer>
              </blockquote>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  <CtaFinal headline="Stai affrontando un passaggio generazionale?" sub="Parliamo del tuo contesto familiare, delle competenze da trasferire e degli obiettivi della nuova generazione. Nessun impegno, nessun costo." />

</BaseLayout>

<style>
  /* ─── PILLAR SECTION ─── */
  .pillar {
    background: var(--color-crema);
  }

  .pillar-inner {
    max-width: 960px;
    margin: 0 auto;
  }

  .back-link {
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-testo-secondario);
    text-decoration: none;
    display: inline-block;
    margin-bottom: 1.5rem;
    transition: color 0.2s ease;
  }

  .back-link:hover {
    color: var(--color-rosso);
  }

  .pillar-badge {
    font-family: var(--font-display);
    font-size: 1.25rem;
    color: var(--color-rosso);
    margin-bottom: 1rem;
  }

  .pillar-title {
    font-size: clamp(2rem, 4.5vw, 3rem);
    margin-bottom: 0.25rem;
  }

  .pillar-subtitle {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-testo-secondario);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 2.5rem;
  }

  .pillar-content {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .pillar-description p {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--color-testo);
    margin-bottom: 1rem;
  }

  .pillar-description p:last-child {
    margin-bottom: 0;
  }

  .pillar-details {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: start;
  }

  @media (min-width: 768px) {
    .pillar-details {
      grid-template-columns: 1fr 1fr;
      align-items: start;
    }
  }

  .detail-block h3 {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-testo-secondario);
    margin-bottom: 1rem;
  }

  .detail-block ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .detail-block li {
    font-size: 0.9375rem;
    color: var(--color-testo);
    padding-left: 1.25rem;
    position: relative;
    line-height: 1.5;
  }

  .detail-block li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-rosso);
  }

  .detail-text {
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--color-testo);
  }

  /* ─── CASI ─── */
  .cases-section {
    background: var(--color-bianco);
  }

  .cases-header {
    max-width: 960px;
    margin: 0 auto 3rem auto;
  }

  .cases-title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    margin-bottom: 0.5rem;
  }

  .cases-sub {
    font-size: 0.9375rem;
    color: var(--color-testo-secondario);
    max-width: 600px;
  }

  .cases-list {
    max-width: 960px;
    margin: 0 auto;
  }

  .case-card {
    padding: 2.5rem 0;
    border-bottom: 1px solid var(--color-bordo);
  }

  .case-card:last-child {
    border-bottom: none;
  }

  .case-header {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 0.5rem;
  }

  .case-name {
    font-family: var(--font-display);
    font-size: 1.5rem;
    color: var(--color-navy);
    margin: 0;
  }

  .case-badge {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-rosso);
  }

  .case-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.25rem;
    margin-bottom: 1.25rem;
  }

  .case-protagonisti {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-testo-secondario);
  }

  .case-dot {
    color: var(--color-testo-secondario);
  }

  .case-duration {
    font-size: 0.875rem;
    color: var(--color-testo-secondario);
  }

  .case-description {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--color-testo);
    margin-bottom: 1.25rem;
    max-width: 760px;
  }

  .case-services {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .service-tag {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-navy);
    padding: 0.3rem 0.75rem;
    background: var(--color-crema);
    border-radius: 100px;
    border: 1px solid var(--color-bordo);
  }

  .case-testimonial {
    background: var(--color-crema);
    border-left: 3px solid var(--color-rosso);
    padding: 1.5rem 2rem;
    margin: 0;
    border-radius: 0 6px 6px 0;
    max-width: 760px;
  }

  .case-testimonial p {
    font-size: 0.9375rem;
    font-style: italic;
    line-height: 1.7;
    color: var(--color-testo);
    margin: 0 0 0.75rem 0;
  }

  .case-testimonial footer {
    font-size: 0.8125rem;
    color: var(--color-testo-secondario);
  }

  .case-testimonial footer strong {
    color: var(--color-navy);
    font-weight: 600;
  }
</style>