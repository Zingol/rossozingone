    flex-direction: column;
    gap: 2.5rem;
  }

  .pillar-description p {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--color-testo);
    margin-bottom: 1rem;
  }

  .pillar-description p:last-child {
    margin-bottom: 0;
  }

