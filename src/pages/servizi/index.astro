---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CtaFinal from '../../components/CtaFinal.astro';
---

<BaseLayout
  title="Fractional CMO/CEO, AI Integration, Advisory per PMI"
  description="Tre pilastri integrati per PMI italiane: Fractional CMO/CEO, AI Integration, Advisory & Discovery. Ogni competenza vive dentro un mandato Fractional — non servizi isolati."
  breadcrumbs={[{ name: "Servizi", href: "/servizi/" }]}
>

  <section class="section servizi-hero">
    <div class="container">
      <div class="servizi-header fade-in">
        <h1 class="servizi-title">Tre pilastri.<br /><span class="servizi-accent">Un unico mandato.</span></h1>
        <p class="servizi-sub">Ogni competenza vive dentro un mandato Fractional. Non sono servizi isolati — sono il modo in cui lavoro nella tua azienda.</p>
      <p class="servizi-sub servizi-ponte">Le tengo insieme in una sola testa perché il problema di un'azienda non rispetta i confini tra reparti — e nemmeno la soluzione.</p>
      </div>
    </div>
  </section>

  <!-- PILLAR 1: Fractional CMO/CEO -->
  <section class="section pillar" id="fractional">
    <div class="container">
      <div class="pillar-inner fade-in">
        <div class="pillar-badge">01</div>
        <h2 class="pillar-title">Fractional CMO / CEO</h2>
        <p class="pillar-subtitle">Direzione strategica dall'interno</p>
        <div class="pillar-content">
          <div class="pillar-description">
            <p>Non vendo giorni. Entro nel sistema decisionale della tua PMI — marketing, business development, direzione aziendale. Tutto connesso, dall'interno.</p>
            <p>Un'agenzia opera fuori. Un consulente consiglia e se ne va. Io resto finché l'azienda non cammina.</p>
          </div>
          <div class="pillar-details">
            <div class="detail-block">
              <h3>Cosa include</h3>
              <ul>
                <li>Marketing strategico e operativo</li>
                <li>General Management e pianificazione strategica</li>
                <li>Business Development e crescita controllata</li>
                <li>Ristrutturazione e turnaround</li>
                <li>Discovery Session — assessment AICIM con metodo BDS</li>
              </ul>
            </div>
            <div class="detail-block">
              <h3>Processo</h3>
              <div class="process-mini">
                <span class="process-step">Assessment</span>
                <span class="process-arrow">&rarr;</span>
                <span class="process-step">Strategize</span>
                <span class="process-arrow">&rarr;</span>
                <span class="process-step">Execute</span>
                <span class="process-arrow">&rarr;</span>
                <span class="process-step">Grow</span>
              </div>
            </div>
          </div>

          <div class="competenze-mandato">
            <h3>Competenze dentro questo mandato</h3>
            <div class="competenze-links">
              <a href="/servizi/digital-marketing/" class="competenza-card">
                <span class="competenza-name">Digital Marketing</span>
                <span class="competenza-frame">Costruisco e gestisco la tua strategia digitale dall'interno — non delegata a un'agenzia esterna.</span>
              </a>
              <a href="/servizi/lead-generation/" class="competenza-card">
                <span class="competenza-name">Lead Generation</span>
                <span class="competenza-frame">Pipeline che il direttore costruisce e governa, non che un fornitore gestisce da fuori.</span>
              </a>
              <a href="/servizi/business-development/" class="competenza-card">
                <span class="competenza-name">Business Development</span>
                <span class="competenza-frame">Crescita che il Fractional CEO governa dall'interno — nuovi mercati, partnership, internazionalizzazione.</span>
              </a>
              <a href="/servizi/gtm-engineering/" class="competenza-card">
                <span class="competenza-name">GTM Engineering</span>
                <span class="competenza-frame">Architettura commerciale AI-integrated — go-to-market come competenza direzionale.</span>
              </a>
              <a href="/servizi/passaggio-generazionale/" class="competenza-card">
                <span class="competenza-name">Passaggio Generazionale</span>
                <span class="competenza-frame">Il fractional come ponte tra generazioni — affiancamento operativo dentro l'azienda.</span>
              </a>
              <a href="/servizi/formazione-aziendale/" class="competenza-card">
                <span class="competenza-name">Formazione Aziendale</span>
                <span class="competenza-frame">Trasferimento di competenze che costruisce autonomia — l'obiettivo è che tu non abbia più bisogno di me.</span>
              </a>
            </div>
          </div>

          <a href="/servizi/fractional-cmo-ceo/" class="pillar-link">Casi cliente e recensioni &rarr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- PILLAR 2: AI Integration -->
  <section class="section pillar pillar-alt" id="ai-integration">
    <div class="container">
      <div class="pillar-inner fade-in">
        <div class="pillar-badge">02</div>
        <h2 class="pillar-title">AI Integration</h2>
        <p class="pillar-subtitle">L'AI nel metodo, non nel reparto</p>
        <div class="pillar-content">
          <div class="pillar-description">
            <p>L'AI non è un progetto. È il modo in cui lavoro dentro la tua azienda — ogni decisione, ogni analisi, ogni processo.</p>
            <p>Il team non deve imparare un tool. Deve diventare il tipo di organizzazione che integra l'AI naturalmente. Approccio privacy-first: quando i tuoi dati sono sensibili, l'elaborazione resta locale.</p>
          </div>
          <div class="pillar-details">
            <div class="detail-block">
              <h3>Cosa include</h3>
              <ul>
                <li>Analisi dei processi aziendali per identificare dove l'AI crea valore</li>
                <li>Automazione workflow e processi ripetitivi</li>
                <li>AI Agents — chatbot, assistenti, automazioni email e WhatsApp</li>
                <li>RAG systems e knowledge base aziendali</li>
                <li>Privacy-first AI con elaborazione locale (Ollama)</li>
              </ul>
            </div>
            <div class="detail-block">
              <h3>Stack tecnologico</h3>
              <div class="tech-stack">
                <span class="tech-tag">Claude</span>
                <span class="tech-tag">OpenAI</span>
                <span class="tech-tag">Gemini</span>
                <span class="tech-tag">Ollama</span>
                <span class="tech-tag">Make</span>
                <span class="tech-tag">n8n</span>
              </div>
            </div>
          </div>

          <div class="competenze-mandato">
            <h3>Competenze dentro questo mandato</h3>
            <div class="competenze-links">
              <a href="/servizi/fractional-caio/" class="competenza-card">
                <span class="competenza-name">Fractional CAIO</span>
                <span class="competenza-frame">Governance AI aziendale — strategia, selezione strumenti, policy, supervisione. Il direttore AI part-time.</span>
              </a>
              <a href="/servizi/piattaforma-elearning-aziendale/" class="competenza-card">
                <span class="competenza-name">Piattaforma E-Learning</span>
                <span class="competenza-frame">Moodle gestito per formazione interna — setup, corsi, gestione continuativa. Dal 2006.</span>
              </a>
            </div>
          </div>

          <a href="/servizi/intelligenza-artificiale-per-pmi/" class="pillar-link">Progetti e partnership &rarr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- PILLAR 3: Advisory & Discovery -->
  <section class="section pillar" id="advisory">
    <div class="container">
      <div class="pillar-inner fade-in">
        <div class="pillar-badge">03</div>
        <h2 class="pillar-title">Advisory & Discovery</h2>
        <p class="pillar-subtitle">Prima di agire, guardo</p>
        <div class="pillar-content">
          <div class="pillar-description">
            <p>Discovery Session, diagnostica BDS, analisi di business — i dati prima delle opinioni. Perché nella mia esperienza, il problema di una PMI è raramente dove il titolare pensa che sia. Non perché sbaglia — perché è troppo dentro per vederlo.</p>
            <p>Prima di investire, acquisire o ristrutturare servono dati. Analizzo mercati, valuto asset digitali e immateriali, conduco due diligence su beni intangibili. Numeri, non opinioni.</p>
          </div>
          <div class="pillar-details">
            <div class="detail-block">
              <h3>Cosa include</h3>
              <ul>
                <li>Discovery Session — assessment AICIM di due ore con metodo BDS</li>
                <li>Analisi e ricerche di mercato</li>
                <li>Business valuation di asset digitali e immateriali</li>
                <li>Business plan e strategie d'impresa</li>
                <li>Supporto all'internazionalizzazione</li>
              </ul>
            </div>
            <div class="detail-block">
              <h3>Per chi è</h3>
              <ul>
                <li>Imprenditori che vogliono capire lo stato reale della propria azienda</li>
                <li>PMI che devono valutare un'acquisizione o una cessione</li>
                <li>Aziende che si preparano all'internazionalizzazione</li>
                <li>Chi cerca un primo confronto strutturato prima di un mandato</li>
              </ul>
            </div>
          </div>

          <a href="/servizi/advisory/" class="pillar-link">Scopri casi e metodo &rarr;</a>
        </div>
      </div>
    </div>
  </section>

  <CtaFinal />

</BaseLayout>

<style>
  .servizi-hero {
    background: var(--color-crema);
    padding-bottom: 2rem;
  }

  .servizi-header {
    max-width: 700px;
    text-align: center;
    margin: 0 auto;
  }

  .servizi-title {
    font-size: clamp(2rem, 4.5vw, 3rem);
    margin-bottom: 0.75rem;
  }

  .servizi-accent {
    color: var(--color-rosso);
  }

  .servizi-sub {
    font-size: 1.0625rem;
    color: var(--color-testo-secondario);
  }

  .servizi-ponte {
    font-style: italic;
    margin-top: 0.5rem;
  }

  .pillar {
    background: var(--color-crema);
  }

  .pillar-alt {
    background: var(--color-bianco);
  }

  .pillar-inner {
    max-width: 960px;
    margin: 0 auto;
  }

  .pillar-badge {
    font-family: var(--font-display);
    font-size: 1.25rem;
    color: var(--color-rosso);
    margin-bottom: 1rem;
  }

  .pillar-title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    margin-bottom: 0.25rem;
  }

  .pillar-subtitle {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-testo-secondario);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 2.5rem;
  }

  .pillar-content {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .pillar-description p {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--color-testo);
    margin-bottom: 1rem;
  }

  .pillar-description p:last-child {
    margin-bottom: 0;
  }

  .pillar-details {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  @media (min-width: 768px) {
    .pillar-details {
      grid-template-columns: 1fr 1fr;
    }
  }

  .detail-block h3 {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-testo-secondario);
    margin-bottom: 1rem;
  }

  .detail-block ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .detail-block li {
    font-size: 0.9375rem;
    color: var(--color-testo);
    padding-left: 1.25rem;
    position: relative;
    line-height: 1.5;
  }

  .detail-block li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-rosso);
  }

  .process-mini {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
  }

  .process-step {
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-navy);
    padding: 0.5rem 1rem;
    background: var(--color-bianco);
    border-radius: 4px;
    border: 1px solid var(--color-bordo);
  }

  .pillar-alt .process-step {
    background: var(--color-crema);
  }

  .process-arrow {
    color: var(--color-rosso);
    font-weight: 700;
  }

  .tech-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tech-tag {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-navy);
    padding: 0.375rem 0.875rem;
    background: var(--color-crema);
    border-radius: 100px;
    border: 1px solid var(--color-bordo);
  }

  .pillar-alt .tech-tag {
    background: var(--color-bianco);
  }

  /* ─── COMPETENZE DENTRO IL MANDATO ─── */
  .competenze-mandato {
    padding-top: 2rem;
    border-top: 1px solid var(--color-bordo);
  }

  .competenze-mandato h3 {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-testo-secondario);
    margin-bottom: 1.25rem;
  }

  .competenze-links {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }

  @media (min-width: 768px) {
    .competenze-links {
      grid-template-columns: 1fr 1fr;
    }
  }

  .competenza-card {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 1.25rem 1.5rem;
    background: var(--color-bianco);
    border: 1px solid var(--color-bordo);
    border-radius: 6px;
    text-decoration: none;
    transition: border-color 0.2s ease, transform 0.15s ease;
  }

  .pillar-alt .competenza-card {
    background: var(--color-crema);
  }

  .competenza-card:hover {
    border-color: var(--color-rosso);
    transform: translateY(-1px);
  }

  .competenza-name {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-navy);
  }

  .competenza-card:hover .competenza-name {
    color: var(--color-rosso);
  }

  .competenza-frame {
    font-size: 0.8125rem;
    line-height: 1.5;
    color: var(--color-testo-secondario);
  }

  /* ─── PILLAR CTA ─── */
  .pillar-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-bianco);
    background: var(--color-navy);
    text-decoration: none;
    padding: 0.75rem 1.75rem;
    border-radius: 6px;
    transition: background 0.2s ease, transform 0.15s ease;
    margin-top: 0.5rem;
  }

  .pillar-link:hover {
    background: var(--color-rosso);
    transform: translateY(-1px);
  }

  .pillar-alt .pillar-link {
    background: var(--color-rosso);
  }

  .pillar-alt .pillar-link:hover {
    background: var(--color-navy);
  }

  .pillar-link-discovery {
    background: transparent;
    color: var(--color-rosso);
    border: 1.5px solid var(--color-rosso);
    margin-left: 0.75rem;
  }

  .pillar-link-discovery:hover {
    background: var(--color-rosso);
    color: var(--color-bianco);
  }
</style>
